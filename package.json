{
  "name": "3d-life-sim",
  "version": "1.0.0",
  "private": true,
  "description": "A real-time 3D particle life simulation powered by WebGPU.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "check": "pnpm lint && pnpm test && pnpm build",
    "check:all": "pnpm check && playwright test",
    "deploy": "pnpm build && wrangler pages deploy && node scripts/verifyDeployedHeaders.mjs"
  },
  "dependencies": {
    "react": "19.2.8",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@webgpu/types": "0.1.71",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kajukabla/3d-life-sim.git"
  },
  "bugs": {
    "url": "https://github.com/kajukabla/3d-life-sim/issues"
  },
  "homepage": "https://3d-life-sim.pages.dev"
}
